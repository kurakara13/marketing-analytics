# Database. Replace <password> with your local Postgres password,
# and ensure the `analytics_dev` database exists (create it via pgAdmin
# or `createdb -U postgres analytics_dev`).
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/analytics_dev

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (platform-owned client; create one Google Cloud project,
# enable Analytics Admin + Data APIs, Google Ads API, create an OAuth 2.0
# Client of type "Web application", add the redirect URI below to its
# allowed list).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connectors/google/callback

# Google Ads developer token (separate from OAuth!). Apply at
# https://ads.google.com → Tools → API Center. Initially issued in "Test"
# mode (only test accounts); apply for "Basic" access for production data.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional: manager (MCC) customer id, required only when accessing
# customers under a manager account. Leave empty for direct access.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# AES-256-GCM key for encrypting connector OAuth tokens at rest.
# 32 bytes / 64 hex chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this key invalidates all stored connector refresh tokens.
ENCRYPTION_KEY=

# Anthropic — used in Phase 3, can be empty for now
ANTHROPIC_API_KEY=
